#!/usr/bin/env bash
# cerebro - meta-harness CLI for the plan -> execute -> review loop.
#
# `cerebro` launches a native interactive `opencode` session as the
# orchestrator. The orchestrator runs as a restricted opencode agent --
# read/grep/glob plus Bash limited to `cerebro ...`, no edit/write/task --
# and a system prompt that catalogues the cerebro sub-commands. The user
# talks only to the orchestrator; the orchestrator spawns short-lived
# sub-agents (`opencode run` on Claude Opus for code work, `opencode run`
# on GPT-5.5 for read-only review) via those sub-commands.
#
# This file is a thin entry point: it resolves its own location (even
# when invoked through a symlink on PATH), sources the modular library
# under ../lib, then dispatches. The implementation lives in lib/*.sh and
# lib/commands/*.sh, with the python helpers under lib/python/ and the
# embedded-file payloads under lib/payloads/ -- see docs/ARCHITECTURE.md
# for the module map.
#
# Top-level invocations the user types at a shell:
#   cerebro                       # mint a new session, drop into the chat
#   cerebro --resume [<id>]       # resume a session (id, or most recent)
#   cerebro list                  # list sessions, newest first
#
# Required: opencode, jq, python3 on PATH. Child opencode runs
# additionally need git and gh for execute / apply-review / doc-write.
#
# Env:
#   CEREBRO_HOME          base dir (default: $HOME/.cerebro)
#   CEREBRO_MODEL         provider/model for the orchestrator + editing children
#                         (default: github-copilot/claude-opus-4.8)
#   CEREBRO_REVIEW_MODEL  provider/model for the read-only reviewer/auditor
#                         (default: github-copilot/gpt-5.5)
#   CEREBRO_TIMEOUT       seconds for child agent calls; 0/empty/none/
#                         unlimited = no cap (default: 0, no cap)
#   CEREBRO_OPENCODE_CMD  opencode executable (default: opencode)
#   CEREBRO_CHILD_SESSION_TTL
#                         seconds a stored child session id stays resumable
#                         before it is treated as stale (default: 86400, 24h)
#   CEREBRO_DEBUG         if 1, verbose logs and leave temp files

# ----- locate the library ---------------------------------------------------
# Resolve symlinks by hand so the install can drop a `cerebro` symlink onto
# PATH while the libs stay beside the real script. macOS lacks `readlink -f`.
_cerebro_src="${BASH_SOURCE[0]}"
while [[ -h "$_cerebro_src" ]]; do
  _cerebro_dir="$(cd -P "$(dirname "$_cerebro_src")" && pwd)"
  _cerebro_src="$(readlink "$_cerebro_src")"
  [[ "$_cerebro_src" != /* ]] && _cerebro_src="$_cerebro_dir/$_cerebro_src"
done
_cerebro_bin_dir="$(cd -P "$(dirname "$_cerebro_src")" && pwd)"
CEREBRO_LIB_DIR="$(cd -P "$_cerebro_bin_dir/../lib" && pwd)"
unset _cerebro_src _cerebro_dir _cerebro_bin_dir

# ----- source the modules ---------------------------------------------------
# Order matters only in that config must come first (it sets shell options and
# env defaults); every other file is just function and string definitions, so
# the command modules can load in any order.
. "$CEREBRO_LIB_DIR/config.sh"
. "$CEREBRO_LIB_DIR/helpers.sh"
. "$CEREBRO_LIB_DIR/payloads.sh"
. "$CEREBRO_LIB_DIR/session-store.sh"
. "$CEREBRO_LIB_DIR/backend.sh"
. "$CEREBRO_LIB_DIR/pair.sh"
for _cerebro_cmd in "$CEREBRO_LIB_DIR"/commands/*.sh; do
  . "$_cerebro_cmd"
done
unset _cerebro_cmd
. "$CEREBRO_LIB_DIR/main.sh"

main "$@"
